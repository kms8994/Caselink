# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# National Law API: use only in local pipeline, not in deployed backend/frontend.
NATIONAL_LAW_API_KEY=

# Embedding
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=auto

# Intake LLM
INTAKE_LLM_PROVIDER=gemini
INTAKE_LLM_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=
INTAKE_LLM_ENABLED=true
INTAKE_MAX_LLM_USER_TURNS=1
INTAKE_READY_CHAR_THRESHOLD=60
INTAKE_TOKEN_BUDGET_CHARS=1800
INTAKE_CACHE_SIZE=128

# Pipeline structure LLM: disabled by default to control cost.
STRUCTURE_LLM_ENABLED=false
STRUCTURE_LLM_MODEL=gemini-2.5-flash-lite
STRUCTURE_LLM_MAX_INPUT_CHARS=8000
STRUCTURE_LLM_MAX_OUTPUT_TOKENS=700
STRUCTURE_LLM_TIMEOUT_SECONDS=30
STRUCTURE_LLM_SLEEP_SECONDS=0.5
STRUCTURE_LLM_ONLY_MISSING=true
STRUCTURE_LLM_CACHE_DIR=data/llm_cache/structure

# Backend
USE_SAMPLE_DATA=true
BACKEND_CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173

# Frontend
PORT=4173
API_BASE_URL=http://127.0.0.1:8001
