# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# National Law API: use only in local pipeline, not in deployed backend/frontend.
NATIONAL_LAW_API_KEY=

# Embedding
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=auto

# Intake LLM
INTAKE_LLM_PROVIDER=gemini
INTAKE_LLM_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=

# Backend
USE_SAMPLE_DATA=true
BACKEND_CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173

# Frontend
PORT=4173
API_BASE_URL=http://127.0.0.1:8001
